# =========================
# Python caches / bytecode
# =========================
__pycache__/
**/__pycache__/
*.py[cod]

# =========================
# Virtualenvs
# =========================
.venv/
venv/

# =========================
# Logs
# =========================
logs/
*.log

# =========================
# Local backups / temp
# =========================
*.bak
*.bak2
*.bak3

# Ignora todo _tmp por defecto, PERO deja versionar scripts/markdown útiles
_tmp/*
!_tmp/**/*.py
!_tmp/**/*.md
_tmp/backup/

# =========================
# Generated runs / heavy outputs (NO versionar)
# =========================
reports/BANK_READY_DELIVERABLE_FINAL_run*/
reports/runs/
reports/inference_*/
reports/inference_portfolio_*/
reports/coordinated_inference_*/
reports/summary/charts/

# Report outputs pesados por defecto
reports/**/*.xlsx
reports/**/*.txt

# =========================
# Local generated data (NO versionar)
# =========================
data/processed/
data/*.xlsx

# =========================
# EXCEPCIONES (sí versionar por auditoría)
# =========================
!reports/canonical/**
!reports/canonical/**/*.csv
!reports/canonical/**/*.json
!reports/canonical/**/CHECKSUMS.txt

!reports/calibration/**
!reports/calibration/**/*.csv
!reports/calibration/**/*.json

!reports/summary/summary_consolidated.csv
!reports/summary/summary_consolidated.json
